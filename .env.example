# Hoops Intel — environment template
# ─────────────────────────────────────
# 1. Vercel: Project → Settings → Environment Variables (Production + Preview).
# 2. GitHub Actions: Repo → Settings → Secrets and variables → Actions.
#
# Never commit filled values. `.env.local` is gitignored for local dev.

# ── Browser (Vite exposes only VITE_* to the client) ─────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Must match `VAPID_PUBLIC_KEY` (URL-safe base64) for /account web push subscribe
VITE_VAPID_PUBLIC_KEY=

# ── Vercel serverless `api/*` + GitHub workflows (server-side) ────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Stripe / Hoops Intel Pro (`api/create-checkout.ts`, `api/stripe-webhook.ts`)
STRIPE_SECRET_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_WEBHOOK_SECRET=
APP_BASE_URL=https://hoopsintel.net

# Web push (`api/push-notify.ts`, workflows)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
PUSH_API_SECRET=
# Workflows targeting production push endpoint:
PUSH_API_URL=

# Email digest (Resend)
RESEND_API_KEY=

# Contact form (`api/contact-intake.ts`)
CONTACT_INBOUND_EMAIL=
CONTACT_FORM_FROM_EMAIL=

# AI edition generators (GitHub Actions + local `scripts/`)
ANTHROPIC_API_KEY=
