{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.hoopsintel.net" }],
      "destination": "https://hoopsintel.net/:path",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/embed/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "functions": {
    "api/push-notify.ts": { "maxDuration": 60 },
    "api/stripe-webhook.ts": { "maxDuration": 60 },
    "api/create-checkout.ts": { "maxDuration": 30 },
    "api/create-portal-session.ts": { "maxDuration": 30 },
    "api/contact-intake.ts": { "maxDuration": 30 },
    "api/embed-analytics.ts": { "maxDuration": 30 },
    "api/embed-analytics-summary.ts": { "maxDuration": 30 }
  }
}
