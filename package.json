{
  "name": "hoops-intel",
  "version": "1.0.0",
  "description": "Hoops Intel — Daily NBA Intelligence Dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test": "node scripts/tests/validate-content.mjs && node scripts/tests/test-assembly.mjs",
    "test:drift": "node scripts/validate-playoff-pulse-drift.mjs",
    "test:generators": "node scripts/content-schedule.mjs --verify-generators",
    "health": "node scripts/health-check.mjs",
