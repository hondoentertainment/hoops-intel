{
  "name": "hoops-intel",
  "version": "1.0.0",
  "description": "Hoops Intel — Daily NBA Intelligence Dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ci": "npm ci --no-audit --no-fund && npm run test:ci:tasks",
    "test:ci:tasks": "vitest run && node scripts/validate-playoff-pulse-drift.mjs && node scripts/content-schedule.mjs --verify-generators && node scripts/verify-edition-season-alignment.mjs && node scripts/validate-archive-duplicates.mjs && node scripts/validate-schema.mjs && node scripts/validate-generated-structure.mjs && node scripts/tests/validate-content.mjs --hard-only && node scripts/verify-deploy-config.mjs && vite build && node scripts/verify-dist-embed.mjs && node scripts/tests/test-assembly.mjs",
    "test": "node scripts/tests/validate-content.mjs --hard-only && node scripts/tests/test-assembly.mjs",
    "test:content": "node scripts/tests/validate-content.mjs --hard-only",
    "test:content:advisory": "node scripts/tests/validate-content.mjs --advisory-only",
    "test:content:all": "node scripts/tests/validate-content.mjs --all",
    "test:drift": "node scripts/validate-playoff-pulse-drift.mjs",
    "playoff:fetch": "node scripts/fetch-playoff-series.mjs",
    "playoff:sync": "node scripts/fetch-playoff-series.mjs && node scripts/sync-playoff-data.mjs",
    "playoff:intel": "node scripts/generate-series-intel.mjs",
    "playoff:movers-lines": "node scripts/compute-playoff-mover-lines.mjs",
    "test:series-intel-keys": "node scripts/verify-series-intel-keys.mjs",
    "test:generators": "node scripts/content-schedule.mjs --verify-generators",
    "health": "node scripts/health-check.mjs",
    "ops:preflight": "node scripts/ops-preflight.mjs",
    "ops:preflight:strict": "node scripts/ops-preflight.mjs --strict",
    "site-review": "node scripts/site-review-agent.mjs",
    "social": "node scripts/post-social.mjs",
    "digest": "node scripts/send-digest.mjs",
    "digest:preview": "node scripts/send-digest.mjs --preview",
    "settle:picks": "node scripts/settle-picks.mjs",
    "test:deploy": "node scripts/verify-deploy-config.mjs"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stripe": "^22.1.0",
    "wouter": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
